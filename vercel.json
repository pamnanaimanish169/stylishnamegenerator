{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.stylishnamegenerator.in" }],
      "destination": "https://stylishnamegenerator.in/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
